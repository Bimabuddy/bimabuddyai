// Environment variables for the insurance policy narrator
PORT=5000
NODE_ENV=development

// OpenAI Configuration (required for AI-powered analysis)
OPENAI_API_KEY=your_openai_api_key_here

// Google Translate API (optional - can use free alternatives)
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

// Text-to-Speech Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

// Alternative: Use Azure Cognitive Services
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_region_here

// OCR Configuration (for scanned documents)
OCR_SPACE_API_KEY=your_ocr_space_api_key_here